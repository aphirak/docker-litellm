# Note: All the variables to this image are optional.
# See README for more information.
# To use, copy this file to 'litellm.env' and uncomment/set your values.

# Master API key for authenticating requests to the LiteLLM proxy.
# - Auto-generated on first start if not set. Shown in container logs.
# - Keep this secret — it has full admin access to the proxy.
# - Use 'docker exec <container> litellm_manage --showkey' to display it.
# LITELLM_MASTER_KEY=sk-my-master-key

# Port for the LiteLLM proxy (default: 4000)
# LITELLM_PORT=4000

# Hostname or IP address shown in startup info and 'litellm_manage --showkey' output.
# Set this if you have a domain name pointing to this server, e.g. litellm.example.com
# If not set, the server's public IP is detected automatically.
# LITELLM_HOST=litellm.example.com

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# LITELLM_LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# Provider API Keys
# Uncomment and set the keys for the providers you want to use.
# Models for each set key are added automatically on first start.
# You can also add or remove models later using 'litellm_manage'.
# -----------------------------------------------------------------------

# OpenAI  →  adds: gpt-4o, gpt-4o-mini
# LITELLM_OPENAI_API_KEY=sk-...

# Anthropic  →  adds: claude-3-6-sonnet (latest)
# LITELLM_ANTHROPIC_API_KEY=sk-ant-...

# Groq  →  adds: llama-3.3-70b
# LITELLM_GROQ_API_KEY=gsk_...

# Google Gemini  →  adds: gemini-2.0-flash
# LITELLM_GEMINI_API_KEY=AIza...

# Ollama (local models)
# Set this to the base URL of your Ollama server  →  adds: ollama/llama3.2
# Use 'host.docker.internal' to reach a service on the Docker host.
# LITELLM_OLLAMA_BASE_URL=http://host.docker.internal:11434

# -----------------------------------------------------------------------
# Database (optional) — enables virtual key management
# Requires an external PostgreSQL server.
# When set, the proxy supports creating per-user/app API keys with
# optional model restrictions, spend budgets, and expiry.
# Manage virtual keys with: docker exec <container> litellm_manage --createkey
# -----------------------------------------------------------------------

# LITELLM_DATABASE_URL=postgresql://litellm:litellm@db:5432/litellm

# -----------------------------------------------------------------------
# MCP Gateway integration (optional)
# When LITELLM_MCP_URL is set, an mcp_servers: block is automatically
# injected into config.yaml on every start, wiring LiteLLM to your
# MCP Gateway so AI clients can call MCP tools through the LiteLLM proxy.
# Use 'mcp' as the hostname when both run in the same Docker network
# (e.g. docker-ai-stack). Use 'host.docker.internal' for a host service.
# Manage MCP servers with: docker exec <container> litellm_manage --listmcp
# -----------------------------------------------------------------------

# MCP Gateway endpoint URL
# LITELLM_MCP_URL=http://mcp:3000/mcp

# MCP Gateway API key (required — get with: docker exec mcp mcp_manage --showkey)
# LITELLM_MCP_API_KEY=mcp-...
